{
  "name": "@codex-mobile/handoff",
  "version": "0.1.0",
  "private": false,
  "description": "Codex Mobile local bridge CLI - outbound-only daemon that mediates codex app-server",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist",
    "resources/codex",
    "README.md"
  ],
  "bin": {
    "handoff": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -p tsconfig.json",
    "dev": "node --watch --experimental-strip-types src/cli.ts",
    "start": "node dist/cli.js",
    "prepack": "npm --prefix ../.. run build:handoff-support && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder for apps/bridge)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@codex-mobile/auth": "0.1.0",
    "@codex-mobile/protocol": "0.1.0",
    "qrcode": "1.5.4",
    "ws": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/qrcode": "1.5.5",
    "@types/ws": "8.5.14",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
