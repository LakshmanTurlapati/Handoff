# Codex Mobile environment contract (Phase 1)
#
# Copy to .env.local (apps/web) or .env (apps/relay, apps/bridge) and fill in real values.
# Never commit real secrets. All keys below are required for Phase 1 to run end-to-end.
#
# For production Fly.io deploys, the same keys are pushed via `flyctl secrets set`
# (automated by .github/workflows/fly-deploy.yml). See README.md -> "Fly.io Deployment"
# for the operator runbook. The "Used by" column below maps each key to the service
# that reads it so operators know which Fly app to target.

# --- Persistence ------------------------------------------------------------

# PostgreSQL connection string used by packages/db (Drizzle) and all apps.
# Used by: apps/web, apps/relay, packages/db
# On Fly.io this is typically injected automatically by `fly postgres attach`.
DATABASE_URL=

# --- Browser auth (apps/web) -----------------------------------------------

# GitHub OAuth credentials for the first-party web sign-in flow (AUTH-01).
# Used by: apps/web
# Create the OAuth app under GitHub -> Settings -> Developer settings -> OAuth Apps.
# Authorization callback URL must be ${NEXTAUTH_URL}/api/auth/callback/github.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Absolute URL the web app is reachable at. Used for OAuth callbacks and
# cookie-scoped redirects. Example: https://app.codex-mobile.dev
# Used by: apps/web
NEXTAUTH_URL=

# --- Session and pairing secrets -------------------------------------------

# Signing key for cm_web_session and cm_device_session cookies. 32+ bytes.
# Used by: apps/web, apps/relay
# Generate with: openssl rand -base64 48
SESSION_COOKIE_SECRET=

# Signing key for single-use pairing tokens minted by the pairing API (PAIR-03).
# Used by: apps/web
# Generate with: openssl rand -base64 48
PAIRING_TOKEN_SECRET=

# Signing key for single-use cm_ws_ticket WebSocket upgrade tickets (SEC-01).
# Must be distinct from SESSION_COOKIE_SECRET so that leaked cookies cannot be
# replayed as WebSocket tickets.
# Used by: apps/web (minting), apps/relay (verification)
# Generate with: openssl rand -base64 48
WS_TICKET_SECRET=

# --- Fly.io deployment targets (Phase 1 / OPS-01) --------------------------

# Fly app name for the public web UI (apps/web).
# Must match the `app = "..."` line in apps/web/fly.toml.
# Fly health check target for this app: GET /api/healthz
FLY_APP_NAME_WEB=

# Fly app name for the public relay/control plane (apps/relay).
# Must match the `app = "..."` line in apps/relay/fly.toml.
# Fly health check target for this app: GET /readyz (service) + GET /healthz (machine)
FLY_APP_NAME_RELAY=
