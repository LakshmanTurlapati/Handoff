{
  "name": "@codex-mobile/protocol",
  "version": "0.1.0",
  "private": false,
  "description": "Shared protocol contracts and event schema for Codex Mobile web, relay, and bridge",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pairing": {
      "types": "./dist/pairing.d.ts",
      "default": "./dist/pairing.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./live-session": {
      "types": "./dist/live-session.d.ts",
      "default": "./dist/live-session.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder for packages/protocol)\"",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
