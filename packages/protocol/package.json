{
  "name": "@codex-mobile/protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Shared protocol contracts and event schema for Codex Mobile web, relay, and bridge",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pairing": {
      "types": "./src/pairing.ts",
      "default": "./src/pairing.ts"
    },
    "./session": {
      "types": "./src/session.ts",
      "default": "./src/session.ts"
    },
    "./live-session": {
      "types": "./src/live-session.ts",
      "default": "./src/live-session.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder for packages/protocol)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
