{
  "name": "@codex-mobile/auth",
  "version": "0.1.0",
  "private": false,
  "description": "Codex Mobile session, device-session, and WebSocket ticket primitives",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./device-session": {
      "types": "./dist/device-session.d.ts",
      "default": "./dist/device-session.js"
    },
    "./ws-ticket": {
      "types": "./dist/ws-ticket.d.ts",
      "default": "./dist/ws-ticket.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist .tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder for packages/auth)\"",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "jose": "6.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
